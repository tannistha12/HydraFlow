{
  "manifest_version": 3,
  "name": "HydraFlow",
  "version": "1.0.0",
  "description": "Track your water intake with reminders",
  "permissions": [
    "storage",
    "notifications",
    "alarms"
  ],
  "host_permissions": [],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "HydraFlow"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}